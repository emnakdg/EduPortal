@model EduPortal.Web.ViewModels.Student.StudentProfileViewModel
@{
    ViewData["Title"] = "Profilim";
}

@if (TempData["success"] != null)
{
    <div class="alert-success"><i class="fas fa-check-circle"></i> @TempData["success"]</div>
}

<div class="page-header">
    <p class="page-subtitle">Öğrenci ve hesap bilgileriniz</p>
</div>

<div class="stats-grid" style="margin-bottom:2rem;">
    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-check-double"></i></div>
        <div class="stat-info">
            <span class="stat-value">@Model.CompletedAssignments</span>
            <span class="stat-label">Tamamlanan</span>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-hourglass-half"></i></div>
        <div class="stat-info">
            <span class="stat-value">@Model.PendingAssignments</span>
            <span class="stat-label">Bekleyen</span>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-chart-line"></i></div>
        <div class="stat-info">
            <span class="stat-value">%@Model.SuccessRate.ToString("0.##")</span>
            <span class="stat-label">Başarı Oranı</span>
        </div>
    </div>
</div>

<div class="card" style="margin-bottom:2rem;">
    <div class="card-header">
        <h3><i class="fas fa-user-graduate"></i> Profil Bilgileri</h3>
    </div>
    <div class="card-body card-body-padded">
        <div class="form-grid">
            <div class="form-group">
                <label>Ad Soyad</label>
                <input class="form-input form-input-no-icon input-readonly" value="@Model.FullName" readonly />
            </div>
            <div class="form-group">
                <label>E-posta</label>
                <input class="form-input form-input-no-icon input-readonly" value="@Model.Email" readonly />
            </div>
            <div class="form-group">
                <label>Öğrenci Numarası</label>
                <input class="form-input form-input-no-icon input-readonly" value="@Model.StudentNumber" readonly />
            </div>
            <div class="form-group">
                <label>Sınıf</label>
                <input class="form-input form-input-no-icon input-readonly" value="@(Model.ClassName ?? "Sınıf atanmamış")" readonly />
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3><i class="fas fa-lock"></i> Şifre Değiştir</h3>
    </div>
    <div class="card-body card-body-padded">
        <p>Hesabınızın güvenliği için şifrenizi düzenli olarak değiştirmeniz önerilir.</p>
        <br />
        <a asp-action="ChangePassword" class="btn-action primary"><i class="fas fa-key"></i> Şifre Değiştir</a>
    </div>
</div>
