@model List<EduPortal.Application.DTOs.AssignmentDto>
@{
    ViewData["Title"] = "Tüm Ödevler";
}

<div class="page-header">
    <p class="page-subtitle">Sistemdeki tüm ödevlerin listesi (Toplam: @Model.Count)</p>
</div>

<div class="card">
    <div class="card-header">
        <h3>Ödev Listesi</h3>
    </div>
    <div class="card-body">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Ödev Başlığı</th>
                    <th>Ders</th>
                    <th>Konu</th>
                    <th>Soru</th>
                    <th>Öğrenci Sayısı</th>
                    <th>Son Tarih</th>
                    <th>Öncelik</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var a in Model)
                    {
                        <tr>
                            <td><strong>@a.Title</strong></td>
                            <td><span class="badge badge-blue">@a.SubjectName</span></td>
                            <td>@a.TopicName</td>
                            <td>@a.QuestionCount</td>
                            <td><span class="badge badge-green">@a.AssignedStudentCount</span></td>
                            <td>@a.DueDate.ToString("dd.MM.yyyy")</td>
                            <td>
                                @if (a.Priority == EduPortal.Domain.Enums.AssignmentPriority.High)
                                {
                                    <span class="badge badge-red">Yüksek</span>
                                }
                                else if (a.Priority == EduPortal.Domain.Enums.AssignmentPriority.Medium)
                                {
                                    <span class="badge badge-orange">Orta</span>
                                }
                                else
                                {
                                    <span class="badge badge-green">Düşük</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="td-empty">
                            Sistemde henüz ödev bulunmuyor.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
